# ENKI x402 Audit Service — environment
# Copy to .env and fill in. For hosts (Render/Railway) you set these in the dashboard.

# Receiving wallet (USDC / Solana). Default is the ENKI Sponge wallet.
PAY_TO=EAMNyeugCfvCyXX4SZ3tUXM6fWxovYJWTCw2JbqmeueR

# Price per audit (USDC). micro-units accepted.
AUDIT_PRICE_USD=$0.05

# Solana mainnet by default. For LOCAL devnet test use: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# CDP facilitator = real mainnet USDC settlement. Free tier: 1000 settles/month.
# Leave BOTH unset to use the x402.org TESTNET facilitator (no signup, devnet only — no real money).
CDP_API_KEY=
CDP_API_SECRET=

# Optional LLM enrichment: none | openai | anthropic
LLM_PROVIDER=none

# Listen port (hosts set this automatically via $PORT; default 4021)
PORT=4021
